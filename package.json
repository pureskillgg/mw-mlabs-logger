{
  "name": "@pureskillgg/mlabs-logger",
  "version": "10.0.1",
  "description": "Standard logger for mlabs services.",
  "type": "module",
  "main": "index.js",
  "exports": {
    "import": "./index.js"
  },
  "module": "index.js",
  "sideEffects": false,
  "keywords": [
    "meltwater",
    "pureskillgg",
    "node"
  ],
  "homepage": "https://github.com/pureskillgg/mw-mlabs-logger",
  "bugs": "https://github.com/pureskillgg/mw-mlabs-logger/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pureskillgg/mw-mlabs-logger.git"
  },
  "license": "MIT",
  "author": {
    "name": "Evan Sosenko",
    "email": "evan@pureskill.gg"
  },
  "files": [
    "package-lock.json",
    "index.js",
    "lib"
  ],
  "scripts": {
    "test": "c8 ava",
    "pretest": "node index.js",
    "test:update": "ava --update-snapshots",
    "test:watch": "ava --watch",
    "test:debug": "ava debug --break",
    "lint": "npm-run-all --parallel lint:*",
    "lint:js": "eslint .",
    "lint:prettier": "prettier --check --ignore-path .gitignore '**/*.{js,cjs,mjs,json,yml,yaml,graphql}'",
    "prepublishOnly": "npm-run-all --parallel lint test",
    "preversion": "npm-run-all --parallel lint test",
    "postversion": "git push --follow-tags",
    "example": "node examples",
    "example:inspect": "node --inspect examples",
    "format": "npm-run-all --parallel format:*",
    "preformat": "prettier --write --ignore-path .gitignore '**/*.{js,cjs,mjs,json,yml,yaml,graphql}'",
    "format:js": "eslint --fix .",
    "report": "c8 report"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@pureskillgg/examplr": "^8.0.1",
    "bunyan-formatter": "^1.0.0",
    "debug": "^4.4.3",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "neostandard": "^0.13.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.4"
  }
}
